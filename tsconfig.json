{
  "extends": "@docusaurus/tsconfig",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@site/*": ["./*"],
      "@components/*": ["./src/components/*"],
      "@theme/*": ["./src/theme/*"]
    },
    "jsx": "react-jsx",
    "strict": true,
    "moduleResolution": "bundler"
  },
  "include": ["src/", "docs/", "docusaurus.config.ts", "sidebars.ts"]
}
